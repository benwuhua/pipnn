# Copy to ~/.config/generic-x86-remote/remote.env and fill real values
REMOTE_HOST=your-x86-host
REMOTE_USER=your-user
REMOTE_PORT=22
REMOTE_WORK_ROOT=/data/work
REMOTE_LOG_DIR=/data/work/logs
SSH_IDENTITY_FILE=~/.ssh/id_ed25519

# Optional
# REMOTE_REPO_DIR=/data/work/pipnn
# REMOTE_BUILD_DIR=/data/work/pipnn/build
# REMOTE_CCACHE_DIR=/data/work/ccache
