# SIFT1M_DIR — 远端数据目录
# Hint: 设置为包含 base.fvecs/query.fvecs/groundtruth.ivecs 的目录
# Required by features: 8,9,10,11
SIFT1M_DIR=

# REMOTE_HOST — generic-x86-remote 主机
# Hint: 在 ~/.config/generic-x86-remote/remote.env 配置同名值
# Required by features: 8,9,10,11
REMOTE_HOST=

# REMOTE_USER — generic-x86-remote 用户
# Hint: 在 ~/.config/generic-x86-remote/remote.env 配置同名值
# Required by features: 8,9,10,11
REMOTE_USER=
